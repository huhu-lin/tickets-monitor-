TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
CHECK_INTERVAL=60

# 場次頁面 URL（帶 PERFORMANCE_ID）
TARGET_URL=https://guardians.fami.life/UTK0204_?PERFORMANCE_ID=P19LRRQA&PRODUCT_ID=P15UU08Q
EVENT_NAME=Guardians UTK0204

# 篩選票區（逗號分隔關鍵字，空白 = 監控全部票區）
# 關鍵字對應頁面上的票區分類，例如：
#   內野、B1層、熱力區、熱區、一般區、L2層、L4層、L5層、外野、輪椅席
# 也可以填票區名稱關鍵字，例如：搖滾、中央
#
# 範例：只監控 B1層 和 外野
# WATCH_ZONES=B1層,外野
#
# 範例：監控所有票區（預設）
WATCH_ZONES=
