TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
CHECK_INTERVAL=60

# 監控目標：可設定多個票種或區域
# 每組用 TARGET_N_NAME（顯示名稱）和 TARGET_N_URL（購票網址）定義
# 數字從 1 開始，連續編號

TARGET_1_NAME=一樓內野區
TARGET_1_URL=https://guardians.fami.life/UTK0204_?PERFORMANCE_ID=P19LRRQA&PRODUCT_ID=P15UU08Q

# 新增第二個票種範例（取消註解後填入對應 URL）：
# TARGET_2_NAME=三樓外野區
# TARGET_2_URL=https://guardians.fami.life/UTK0204_?PERFORMANCE_ID=P19LRRQA&PRODUCT_ID=xxxxxxxxx

# TARGET_3_NAME=二樓看台區
